# Jitsi WebRTC Bot - Пример конфигурации
# Скопируйте этот файл в .env и настройте под ваш сервер

# ==== Jitsi Connection Settings ====
# URL вашего Jitsi сервера
JITSI_URL=https://meet.recontext.online

# Название комнаты для записи
JITSI_ROOM=testmeet

# XMPP домены (обычно не нужно менять)
XMPP_DOMAIN=meet.jitsi
MUC_DOMAIN=muc.meet.jitsi
FOCUS_JID=focus.meet.jitsi

# Имя бота в конференции
BOT_NICKNAME=recorder-bot

# ==== Recording Settings ====
# Директория для сохранения записей
RECORD_DIR=./recordings

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# ==== S3 Storage (optional) ====
# Endpoint S3-совместимого хранилища
S3_ENDPOINT=https://api.storage.recontext.online

# Название bucket для записей
S3_BUCKET=jitsi-recordings

# Credentials для S3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
