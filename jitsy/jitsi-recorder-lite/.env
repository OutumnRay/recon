# Jitsi Meet Configuration
JITSI_URL=https://meet.recontext.online
JITSI_DOMAIN=meet.recontext.online

# Prosody XMPP (для Docker используй 'prosody', локально - IP адрес)
PROSODY_HOST=prosody
PROSODY_PORT=5222
XMPP_DOMAIN=meet.jitsi
MUC_DOMAIN=muc.meet.jitsi

# Jitsi Videobridge
JVB_HOST=jvb
JVB_PORT=8080

# S3 Storage (MinIO или AWS S3)
S3_ENDPOINT=https://api.storage.recontext.online
S3_BUCKET=jitsi-recordings
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# Webhook (опционально)
WEBHOOK_URL=

# Redis (для координации между инстансами)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_ENABLED=true

# Recording Settings
RECORD_DIR=/tmp/recordings
AUDIO_BITRATE=48k
CHECK_INTERVAL=5
RECONNECT_TIMEOUT=30

# Bot Identity
BOT_NAME=Recorder Bot
BOT_NICKNAME=recorder

# HTTP Server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Logging
LOG_LEVEL=DEBUG

# Worker ID (автоматически в Docker)
# HOSTNAME=recorder-1
