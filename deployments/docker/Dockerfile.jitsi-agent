# Build stage
FROM golang:1.24-alpine AS builder

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum* ./
RUN go mod download

# Copy source code
COPY . .

# Build the application
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o jitsi-agent ./cmd/jitsi-agent

# Runtime stage
FROM alpine:latest

# Install dependencies for WebRTC and media processing
RUN apk --no-cache add \
    ca-certificates \
    ffmpeg \
    gst-plugins-base \
    gst-plugins-good \
    gst-plugins-bad \
    gst-plugins-ugly \
    gst-libav

WORKDIR /root/

# Copy the binary from builder
COPY --from=builder /app/jitsi-agent .

# Expose port
EXPOSE 8084

# Run the application
CMD ["./jitsi-agent"]
