# Build stage
FROM golang:1.24-alpine AS builder

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum* ./
RUN go mod download

# Copy source code
COPY . .

# Build the application
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o transcription-worker ./cmd/transcription-worker

# Runtime stage
FROM python:3.11-slim

# Install system dependencies for Whisper
RUN apt-get update && apt-get install -y \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
RUN pip install --no-cache-dir \
    openai-whisper \
    faster-whisper

WORKDIR /root/

# Copy the Go binary from builder
COPY --from=builder /app/transcription-worker .

# Expose port for health checks
EXPOSE 8082

# Run the application
CMD ["./transcription-worker"]
