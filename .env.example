# =============================================================================
# Recontext — локальная конфигурация для разработчиков
# Скопируйте этот файл в .env и измените нужные значения:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_USER=recontext
DB_PASSWORD=recontext
DB_NAME=recontext
POSTGRES_PORT=5432          # порт PostgreSQL на хосте

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_USER=recontext
RABBITMQ_PASSWORD=recontext
RABBITMQ_PORT=5672          # AMQP
RABBITMQ_MGMT_PORT=15672    # веб-интерфейс: http://localhost:15672

# -----------------------------------------------------------------------------
# MinIO
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=recontext
MINIO_PORT=9000             # S3 API
MINIO_CONSOLE_PORT=9001     # веб-интерфейс: http://localhost:9001

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6380             # mapped на хосте (внутри контейнера всегда 6379)
REDIS_TASK_QUEUE=recontext:transcription:queue
REDIS_RESULT_QUEUE=recontext:transcription:results

# -----------------------------------------------------------------------------
# Порты порталов
# -----------------------------------------------------------------------------
MANAGING_PORTAL_PORT=20080  # http://localhost:20080
USER_PORTAL_PORT=20081      # http://localhost:20081

# URL пользовательского портала (для генерации ссылок-приглашений)
PORTAL_URL=http://localhost:20081

# -----------------------------------------------------------------------------
# Whisper / транскрипция
# -----------------------------------------------------------------------------
WHISPER_MODEL=base          # base / small / medium / large
WHISPER_DEVICE=cpu          # cpu / cuda
WHISPER_LANGUAGE=ru

# Diarization (определение спикеров)
# Получить токен: https://huggingface.co/settings/tokens
HF_TOKEN=
ENABLE_DIARIZATION=false    # требует HF_TOKEN

# Qdrant (векторный поиск)
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_ENABLED=false

# -----------------------------------------------------------------------------
# LiveKit (видеоконференции) — опционально
# Оставьте пустыми, если не используете LiveKit локально
# -----------------------------------------------------------------------------
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WEBHOOK_DEBUG=false

# LiveKit Egress (запись конференций) — опционально
LIVEKIT_EGRESS_ENABLED=false
LIVEKIT_EGRESS_S3_ENDPOINT=
LIVEKIT_EGRESS_S3_BUCKET=recontext
LIVEKIT_EGRESS_S3_ACCESS_KEY=minioadmin
LIVEKIT_EGRESS_S3_SECRET=minioadmin
LIVEKIT_EGRESS_S3_REGION=
LIVEKIT_EGRESS_RECORD_TRACKS=false

# -----------------------------------------------------------------------------
# SMTP (отправка email) — опционально
# Оставьте пустыми для отключения отправки писем
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@localhost
SMTP_FROM_NAME=Recontext

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging (push-уведомления) — опционально
# Вставьте содержимое JSON-файла credentials в одну строку,
# либо оставьте пустым для отключения push-уведомлений
# -----------------------------------------------------------------------------
FCM_CREDENTIALS_JSON=

# -----------------------------------------------------------------------------
# LLM (генерация резюме встреч) — опционально
# Совместимо с любым OpenAI-совместимым API (OpenAI, Ollama, LM Studio и др.)
# -----------------------------------------------------------------------------
LLM_API_ENDPOINT=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# -----------------------------------------------------------------------------
# Прочее
# -----------------------------------------------------------------------------
APP_VERSION=0.1.0+0
DEBUG_LOGS_ENABLED=false
LOG_LEVEL=INFO
